#!/usr/bin/env sh
# pre-push:重量检查,跑全量测试 + 覆盖率门槛
# 只在 feature/mcp-server 分支强制(其他分支可宽松)

BRANCH=$(git rev-parse --abbrev-ref HEAD)
echo "[pre-push] branch=$BRANCH"

# 类型检查
npx tsc --noEmit || { echo "✗ TypeScript check failed"; exit 1; }

# 前端测试
npx vitest run || { echo "✗ FE tests failed"; exit 1; }

# Rust 测试(需 cargo 在 PATH)
if command -v cargo >/dev/null 2>&1; then
  (cd src-tauri && cargo test --lib) || { echo "✗ Rust tests failed"; exit 1; }
else
  echo "[pre-push] cargo not in PATH, skip Rust tests"
fi

# 覆盖率门槛
if [ -f scripts/check-coverage.cjs ]; then
  node scripts/check-coverage.cjs || { echo "✗ Coverage below threshold"; exit 1; }
fi

echo "[pre-push] ✓ all checks passed"
